# === 推送渠道配置 ===
# 支持多个渠道同时推送，用逗号分隔
#   desktop   = macOS 系统通知（默认，零配置）
#   pushplus  = 推送到微信（需注册 pushplus.plus 获取 Token）
#   wecom_bot = 企业微信群机器人（需配置 Webhook URL）
NOTIFIER_TYPES=desktop,wecom_bot

# --- 企业微信 Bot ---
# 在企业微信群中添加机器人，复制 Webhook URL
WECOM_WEBHOOK_URL=your_webhook_url_here

# --- PushPlus（备选）---
# 注册地址: http://pushplus.plus
PUSHPLUS_TOKEN=

# 调试模式
DEBUG=false
