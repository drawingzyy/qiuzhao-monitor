<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN"
  "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.qiuzhao.daily-scan</string>

    <key>ProgramArguments</key>
    <array>
        <string>/usr/bin/python3</string>
        <string>-m</string>
        <string>qiuzhao.main</string>
    </array>

    <key>WorkingDirectory</key>
    <string>/Users/beibeibei/qiuzhao-monitor</string>

    <key>EnvironmentVariables</key>
    <dict>
        <key>PATH</key>
        <string>/usr/local/bin:/usr/bin:/bin:/opt/homebrew/bin</string>
    </dict>

    <!-- 每天北京时间 8:00 运行 -->
    <key>StartCalendarInterval</key>
    <dict>
        <key>Hour</key>
        <integer>8</integer>
        <key>Minute</key>
        <integer>0</integer>
    </dict>

    <!-- 把日志写到本地 -->
    <key>StandardOutPath</key>
    <string>/Users/beibeibei/qiuzhao-monitor/logs/launchd-stdout.log</string>
    <key>StandardErrorPath</key>
    <string>/Users/beibeibei/qiuzhao-monitor/logs/launchd-stderr.log</string>

    <key>RunAtLoad</key>
    <false/>
</dict>
</plist>
